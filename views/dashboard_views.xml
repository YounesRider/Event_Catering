<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_event_catering_dashboard" model="ir.ui.view">
        <field name="name">event.catering.dashboard</field>
        <field name="model">event.catering.dashboard</field>
        <field name="arch" type="xml">

            <form string="Tableau de bord">
                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>


                    <group>

                        <group string="Statistiques">

                            <field name="total_events"
                                   readonly="1"/>

                            <field name="confirmed_events"
                                   readonly="1"/>

                        </group>


                        <group string="État">

                            <field name="running_events"
                                   readonly="1"/>

                            <field name="done_events"
                                   readonly="1"/>

                        </group>

                    </group>


                </sheet>
            </form>

        </field>
    </record>


    


</odoo>